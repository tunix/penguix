{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":enablePreCommit"],
  "prHourlyLimit": 10,
  "prConcurrentLimit": 20,
  "recreateWhen": "always",
  "rebaseWhen": "auto",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track pinned container images in Justfile variables",
      "managerFilePatterns": ["/^Justfile$/"],
      "matchStrings": [
        "export\\s+\\w+\\s+:=\\s+env\\(\"[^\"]+\",\\s+\"(?<packageName>[^\\s:@]+(?:/[^\\s:@]+)+):(?<currentValue>[^\\s@\"]+)@(?<currentDigest>sha256:[a-f0-9]+)\"\\)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track pinned tool versions in workflow env vars",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.yml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n\\s+\\w+: \"(?<currentValue>[^\"]+)\""
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Automerge safe low-risk updates (digest/pin only) when checks pass",
      "matchUpdateTypes": ["digest", "pin", "pinDigest"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Keep the shared projectbluefin actions channel fresh",
      "matchPackageNames": ["projectbluefin/actions"],
      "matchUpdateTypes": ["digest", "pinDigest", "pin", "patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Keep first-party OCI context images fresh immediately",
      "matchDepNames": ["ghcr.io/projectbluefin/common", "ghcr.io/ublue-os/brew"],
      "matchUpdateTypes": ["digest", "pinDigest", "pin"],
      "automerge": true,
      "schedule": ["at any time"]
    },
    {
      "description": "Do not automatically cross Fedora major releases",
      "matchDepNames": ["quay.io/fedora-ostree-desktops/silverblue"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
