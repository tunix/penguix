# Desktop: background, interface, WM, sound, peripherals, privacy

[org/gnome/desktop/background]
picture-options = 'zoom'
primary-color = '000000'
secondary-color = 'FFFFFF'

[org/gnome/desktop/interface]
accent-color = 'teal'
enable-hot-corners = false
clock-format = '24h'
clock-show-date = true
clock-show-weekday = true
cursor-theme = "Yaru"
text-scaling-factor = 0.9
monospace-font-name = 'JetBrains Mono Regular 11'

[org/gnome/desktop/wm/preferences]
button-layout = 'appmenu:minimize,maximize,close'

[org/gnome/desktop/wm/keybindings]
# Unbind Ctrl+Alt arrows so Ghostty split navigation can use them.
switch-to-workspace-left = ['<Super>Page_Up', '<Super>KP_Prior', '<Super><Alt>Left']
switch-to-workspace-right = ['<Super>Page_Down', '<Super>KP_Next', '<Super><Alt>Right']
switch-to-workspace-up = @as []
switch-to-workspace-down = @as []
move-to-workspace-left = ['<Super><Shift>Page_Up', '<Super><Shift>KP_Prior', '<Super><Shift><Alt>Left']
move-to-workspace-right = ['<Super><Shift>Page_Down', '<Super><Shift>KP_Next', '<Super><Shift><Alt>Right']
move-to-workspace-up = @as []
move-to-workspace-down = @as []

[org/gnome/desktop/sound]
allow-volume-above-100-percent = true
event-sounds = true
theme-name = "freedesktop"

[org/gnome/desktop/peripherals/keyboard]
repeat = true
repeat-interval = 30

[org/gnome/desktop/peripherals/touchpad]
tap-to-click = true
send-events = true
natural-scroll = true
two-finger-scrolling-enabled = true
disable-while-typing = true

[org/gnome/desktop/peripherals/mouse]
natural-scroll = false

[org/gnome/desktop/privacy]
remove-old-trash-files = true
remove-old-temp-files = true
old-files-age = 3
