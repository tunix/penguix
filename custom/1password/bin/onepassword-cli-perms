#!/usr/bin/env bash

# Re-apply root:onepassword-cli ownership and the setgid bit on Homebrew-installed
# `op` binaries. Required for 1Password desktop app integration; Homebrew resets
# ownership/permissions on every `brew upgrade 1password-cli`.
# https://developer.1password.com/docs/cli/app-integration/

set -euo pipefail
shopt -s nullglob

CASKROOM="${CASKROOM:-/home/linuxbrew/.linuxbrew/Caskroom/1password-cli}"

# Nothing to do if the cask isn't installed
[ -d "${CASKROOM}" ] || exit 0

# Group is normally created by sysusers.d at boot; this is a fallback
getent group onepassword-cli >/dev/null || groupadd --system onepassword-cli

# Homebrew creates the version directory before extracting into it; wait for
# at least one op binary to show up (up to 30s) before fixing permissions.
found=""
for _ in {1..30}; do
	for op in "${CASKROOM}"/*/op; do
		[ -f "${op}" ] && found=1 && break 2
	done
	sleep 1
done
[ -n "${found}" ] || exit 0

for op in "${CASKROOM}"/*/op; do
	[ -f "${op}" ] || continue
	if [ "$(stat -c '%U:%G' "${op}")" != "root:onepassword-cli" ]; then
		chown root:onepassword-cli "${op}"
		echo "Fixed ownership of ${op}"
	fi
	mode="$(stat -c '%a' "${op}")"
	if (((0${mode} & 02000) == 0)); then
		chmod g+s "${op}"
		echo "Set setgid bit on ${op}"
	fi
done
